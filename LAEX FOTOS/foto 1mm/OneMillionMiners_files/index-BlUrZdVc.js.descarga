{{brandMiners}} 100% स्वचालित ब्लॉकचेन पर चलता है,
मानवीय त्रुटि और नौकरशाही को ख़त्म करना।`,titleHighlight:"पूरी तरह से स्वचालित",titlePrefix:"जानें कि $20 डॉलर को एक डॉलर में कैसे बदला जाए",ctaActivate:"{{brandMiners}} खरीदें",joinTelegramChannel:"टेलीग्राम चैनल से जुड़ें",joinWhatsappChannel:"व्हाट्सएप चैनल से जुड़ें",joinTelegramGroup:"टेलीग्राम ग्रुप से जुड़ें"},howWorksSection:{collective:{desc:'"सामूहिक प्रयास से आपको लाभ होता है"',title:"सामूहिक प्रयास"},matrix:{desc:"इसमें 16 एक साथ खदानों के तीन अनुबंध और {{brandTurbo}} नामक चौथा स्मार्ट अनुबंध और तीन क्रिप्टोग्राफ़िक मुद्राएं हैं।",status:"पूरी तरह से स्वचालित प्रणाली",title:"फोर्स्ड मैट्रिक्स, फॉलो मी, डायनेमिक कंप्रेशन और स्पिल के साथ"},optimization:{desc:"अधिक पद सक्रिय करें = अधिक मशीनें आपके लिए काम करेंगी। सभी पदों से स्पिल उत्पन्न करें, न केवल आपके प्रत्यक्ष पदों से बल्कि आपकी पूरी टीम और आपके अपलाइन से।",note:"इसमें कोई मध्यस्थ नहीं है, जो आपको अनुबंध से जुड़े अपने वॉलेट में सीधे लाभ प्राप्त करने की अनुमति देता है।",title:"स्थिति अनुकूलन"},subtitle:"कारण कि यह मॉडल किसी भी पारंपरिक प्रणाली की तुलना में तेजी से बढ़ता है।",title:"एक मिलियन खनिकों के अनुबंध कैसे काम करते हैं"},nav:{benefits:"फ़ायदे",faq:"अक्सर पूछे जाने वाले प्रश्न",home:"शुरू",whatIs:"क्या है",howItWorks:"यह काम किस प्रकार करता है",connect:"वॉलेट कनेक्ट करें"},packages:{diamantes:"हीरे",esmeraldas:"पन्ना",oro:"सोना",plata:"प्लैटिनम"},startSection:{step1:{desc:"अपना वॉलेट ब्राउज़र दर्ज करें और डोमेन http://www.onemillionminers.com लोड करें",title:"1"},step2:{desc:"{{brandMiners}} अनुबंध खरीदें और यदि आप चाहें तो {{brandTurbo}}",title:"2"},step3:{desc:"एक बार जब आपकी स्थिति सक्रिय हो जाए, तो अपना रेफरल लिंक प्राप्त करें और बेहतरीन पुरस्कार पाने के लिए इसे अधिक से अधिक लोगों के साथ साझा करें।",title:"3"},step4:{desc:"इन चरणों का पालन करके आप {{brandMiners}} के भीतर एक सहयोगी अर्थव्यवस्था पारिस्थितिकी तंत्र में भाग लेंगे",title:"4"},cta:"अभी सक्रिय करें",subtitle:"अपने MINA को 3 मिनट से भी कम समय में और सरल चरणों के साथ सक्रिय करें",title:"शुरू कैसे करें"},whatIsSection:{automated:{desc:"आय बिना प्रतीक्षा किए तुरंत वितरित की जाती है। बुद्धिमान एल्गोरिदम स्वायत्त रूप से लाभ निपटान का प्रबंधन करते हैं।",title:"स्वचालित"},decentralized:{desc:"यह ब्लॉकचेन पर चलता है, इसे कोई भी संशोधित या बंद नहीं कर सकता है। नेटवर्क अपरिवर्तनीय कोड द्वारा शासित होता है, जो आपकी संपत्ति की संप्रभुता की गारंटी देता है।",title:"विकेन्द्रीकृत"},transparent:{desc:"सभी लेनदेन सार्वजनिक और सत्यापन योग्य हैं। वितरित खाता-बही यह सुनिश्चित करता है कि प्रत्येक पूंजी संचलन वास्तविक समय में ऑडिट योग्य है।",title:"पारदर्शी"},subtitle:`{{brandMiners}} 4 पूर्णतः स्मार्ट अनुबंधों का एक डिजिटल पारिस्थितिकी तंत्र है
स्वचालित, एक आर्थिक मॉडल के माध्यम से लोगों को जोड़ने के लिए डिज़ाइन किया गया
