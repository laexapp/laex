ntracts:e$,common:t$,coupons:n$,dashboard:a$,eraRewards:r$,orderHistory:i$,referrals:s$,settings:o$,sidebar:l$,users:c$,validation:u$,register:d$,header:f$},m$={benefitsSection:{accessible:{desc:"குறைந்த விலை மற்றும் அதிக லாபத்துடன் தொடங்குங்கள்.",title:"அணுகக்கூடிய நுழைவாயில்"},duplicable:{desc:"பங்கேற்க எவரும் மற்றவர்களை அழைக்கலாம் மற்றும் நீங்கள் 10 X 10 உத்தியைப் பயன்படுத்தினால், உங்கள் பலன்களை விரைவுபடுத்துவீர்கள்.",title:"நகலெடுக்கக்கூடியது"},global:{desc:"எந்த நாட்டிலிருந்தும் பங்கேற்கலாம், 24/7.",title:"உலகளாவிய"},secure:{desc:"தணிக்கை செய்யப்பட்ட ஒப்பந்தம்.",title:"நிச்சயமாக"},simple:{desc:"விளக்கவும் விண்ணப்பிக்கவும் எளிதானது.",title:"எளிமையானது"},badge:"மூலோபாய மதிப்பு",subtitle:"இன்றே உங்கள் சுரங்கங்களை ஏன் செயல்படுத்த வேண்டும்.",title:"முக்கிய நன்மைகள்"},countdown:{days:"நாட்கள்",hours:"மணிநேரம்",launched:"நேரடி வெளியீடு!",minutes:"நிமிடங்கள்",seconds:"நொடிகள்"},ctaBanner:{subtitle:"உலகளவில் கிடைக்கிறது • KYC இல்லை • 100% ஆன்-செயின்",title:"இன்றே எதிர்காலத்தை சுரங்கப்படுத்தத் தொடங்குங்கள்",btn:"{{brandMiners}} ஐ வாங்கவும்"},faqSection:{a1:"ஆம், {{brandMiners}} பிளாக்செயினில் தணிக்கை செய்யப்பட்ட மற்றும் மாறாத ஸ்மார்ட் ஒப்பந்தங்களில் இயங்குகிறது, உங்கள் நிதி மற்றும் தொடர்புகள் நேரடியாகவும் பாதுகாக்கப்படுவதையும் உறுதி செய்கிறது.",a3:"பிளாக்செயினுடன் இணைக்கப்பட்ட உங்கள் தனிப்பட்ட பணப்பைக்கு நேரடியாகவும் உடனடியாகவும் வருமானம் விநியோகிக்கப்படுகிறது. திரும்பப் பெறுவதற்கான கோரிக்கை அல்லது ஒப்புதல் தேவையில்லை.",desc2:"இது கண்டிப்பாக தேவையில்லை, ஆனால் உங்கள் பரிந்துரை இணைப்பைப் பகிர்வது உங்கள் வருமானத்தை கணிசமாக விரைவுபடுத்துகிறது மற்றும் டீம் ஸ்பில் ரிவார்டுகளைத் திறக்கிறது.",q1:"இது பாதுகாப்பானதா?",q2:"நான் மக்களை அழைக்க வேண்டுமா?",q3:"எனது வெற்றிகளை நான் எவ்வாறு திரும்பப் பெறுவது?",title:"FAQ - அடிக்கடி கேட்கப்படும் கேள்விகள்"},footer:{contact:"தொடர்பு கொள்ளவும்",copyright:"© 2024 {{brandMiners}}. சுரங்கத்தில் நிறுவன எதிர்காலம்.",privacy:"தனியுரிமை",terms:"விதிமுறைகள்"},hero:{ctaDoc:"ஆவணப்படுத்தலைப் பார்க்கவும்",joinWhatsApp:"வாட்ஸ்அப் குழுவில் சேரவும்",subtitle:`மையப்படுத்தப்பட்ட அமைப்புகள் மற்றும் வெற்று வாக்குறுதிகளால் சோர்வடைகிறீர்களா?
{{brandMiners}} 100% தானியங்கி பிளாக்செயினில் இயங்குகிறது,
மனித தவறு மற்றும் அதிகாரத்துவத்தை நீக்குதல்.`,titleHighlight:"முற்றிலும் தானியங்கி",titlePrefix:"$20 டாலர்களை எப்படி a ஆக மாற்றுவது என்பதைக் கண்டறியவும்",ctaActivate:"{{brandMiners}} வாங்கவும்",joinTelegramChannel:"டெலிகிராம் சேனலில் சேரவும்",joinWhatsappChannel:"வாட்ஸ்அப் சேனலில் சேரவும்",joinTelegramGroup:"டெலிகிராம் குழுவில் சேரவும்"},howWorksSection:{collective:{desc:'"கூட்டு முயற்சி உங்களுக்கு நன்மை பயக்கும்"',title:"கூட்டு முயற்சி"},matrix:{desc:"இது 16 ஒரே நேரத்தில் சுரங்கங்களின் மூன்று ஒப்பந்தங்களையும், {{brandTurbo}} எனப்படும் நான்காவது ஸ்மார்ட் ஒப்பந்தத்தையும் மூன்று கிரிப்டோகிராஃபிக் கரன்சிகளையும் கொண்டுள்ளது.",status:"முழுமையாக தானியங்கி அமைப்பு",title:"ஃபோர்ஸ்டு மேட்ரிக்ஸ், ஃபாலோ மீ உடன், டைனமிக் கம்ப்ரஷன் மற்றும் ஸ்பில்"},optimization:{desc:"அதிக நிலைகளை இயக்கவும் = உங்களுக்காக வேலை செய்யும் அதிக இயந்திரங்கள். உங்கள் நேரடி நிலைகள் மட்டுமின்றி உங்கள் முழு குழு மற்றும் உங்கள் மேல்நிலையிலிருந்தும் அனைத்து நிலைகளிலிருந்தும் கசிவுகளை உருவாக்குங்கள்.",note:"இடைத்தரகர்கள் இல்லை, இது ஒப்பந்தத்துடன் தொடர்புடைய உங்கள் பணப்பைக்கு நேரடி பலன்களைப் பெற உங்களை அனுமதிக்கிறது.",title:"நிலை மேம்படுத்தல்"},subtitle:"இந்த மாதிரியானது எந்த வழக்கமான அமைப்பையும் விட வேகமாக அளவிடுவதற்கான காரணங்கள்.",title:"OneMillionMiners ஒப்பந்தங்கள் எப்படி வேலை செய்கின்றன"},nav:{benefits:"நன்மைகள்",faq:"அடிக்கடி கேட்கப்படும் கேள்விகள்",home:"தொடங்கு",whatIs:"என்ன",howItWorks:"இது எப்படி வேலை செய்கிறது",connect:"Wallet ஐ இணைக்கவும்"},packages:{diamantes:"வைரங்கள்",esmeraldas:"மரகதம்",oro:"தங்கம்",plata:"பிளாட்டினம்"},startSection:{step1:{desc:"உங்கள் வாலட் உலாவியை உள்ளிட்டு http://www.onemillionminers.com டொமைனை ஏற்றவும்",title:"1"},step2:{desc:"{{brandMiners}} ஒப்பந்தங்களை வாங்கவும், நீங்கள் விரும்பினால், {{brandTurbo}}",title:"2"},step3:{desc:"உங்கள் நிலை செயல்பட்டவுடன், உங்கள் பரிந்துரை இணைப்பைப் பெற்று, சிறந்த வெகுமதிகளைப் பெற, முடிந்தவரை பலருடன் பகிர்ந்து கொள்ளுங்கள்.",title:"3"},step4:{desc:"இந்தப் படிகளைப் பின்பற்றுவதன் மூலம், நீங்கள் {{brandMiners}}-க்குள் கூட்டுப் பொருளாதாரச் சூழல் அமைப்பில் பங்கேற்பீர்கள்.",title:"4"},cta:"இப்போது செயல்படுத்தவும்",subtitle:"உங்கள் மினாவை 3 நிமிடங்களுக்குள் மற்றும் எளிய படிகளில் செயல்படுத்தவும்",title:"எப்படி தொடங்குவது"},whatIsSection:{automated:{desc:"வருமானம் காத்திருக்காமல், உடனடியாக விநியோகிக்கப்படுகிறது. அறிவார்ந்த வழிமுறைகள் இலாப தீர்வை தன்னாட்சி முறையில் நிர்வகிக்கின்றன.",title:"தானியங்கி"},decentralized:{desc:"இது பிளாக்செயினில் இயங்குகிறது, அதை யாராலும் மாற்றவோ நிறுத்தவோ முடியாது. நெட்வொர்க் மாறாத குறியீட்டால் நிர்வகிக்கப்படுகிறது, உங்கள் சொத்துக்களின் இறையாண்மைக்கு உத்தரவாதம் அளிக்கிறது.",title:"பரவலாக்கப்பட்டது"},transparent:{desc:"அனைத்து பரிவர்த்தனைகளும் பொது மற்றும் சரிபார்க்கக்கூடியவை. ஒவ்வொரு மூலதன இயக்கமும் உண்மையான நேரத்தில் தணிக்கை செய்யப்படுவதை விநியோகிக்கப்பட்ட லெட்ஜர் உறுதி செய்கிறது.",title:"வெளிப்படையானது"},subtitle:`{{brandMiners}} என்பது 4 முழு ஸ்மார்ட் ஒப்பந்தங்களின் டிஜிட்டல் சுற்றுச்சூழல் அமைப்பாகும்
தானியங்கி, பொருளாதார மாதிரி மூலம் மக்களை இணைக்க வடிவமைக்கப்பட்டுள்ளது
கூட்டு மற்றும் பிளாக்செயின் தொழில்நுட்பத்துடன்.`,title:"{{brandMiners}} என்றால் என்ன?"},comingSoon:{badge:"விரைவில் தொடங்கு",contact:"தொடர்பு கொள்ளவும்",footerCopyright:"© 2024 {{brandMiners}}. அனைத்து உரிமைகளும் பாதுகாக்கப்பட்டவை.",privacy:"தனியுரிமைக் கொள்கை",subtitle:"சமூகத்தின் சக்தி மற்றும் தானியங்கி சுரங்க தொழில்நுட்பத்தை ஒருங்கிணைக்கும் இறுதி தளத்தை நாங்கள் உருவாக்குகிறோம். வளத்தை நோக்கிய பயணம் தொடங்க உள்ளது.",tagline:"சுரங்கம், சமூகம் மற்றும் லாபம் ஒரே இடத்தில்",terms:"சேவை விதிமுறைகள்"},treasuresSection:{subtitle:"நீங்கள் முதன்முறையாக 12 யுகங்களில் ஒரு சுழற்சியை முடிக்கும்போது, ​​நீங்கள் ஒரு புதையலைப் பெறுவீர்கள்",diamantesValue:"OMDB இல் $10,000 பொக்கிஷங்கள்",esmeraldasValue:"OMDB இல் $5,000 பொக்கிஷங்கள்",oroValue:"OMDB இல் $300 பொக்கிஷங்கள்",plataValue:"OMDB இல் $1,000 பொக்கிஷங்கள்",title:"ஒவ்வொரு காலத்திலும் பொக்கிஷங்கள்"},matrixSection:{title:"அணி 2×2"},turboMinersSection:{subtitle:"{{brandTurbo}} என்பது ஒரு ஒற்றை சுழற்சி மற்றும் அதன் செயல்பாடு {{brandMiners}} ஒப்பந்தத்தை தானாக வாங்குவது அல்லது நீங்கள் ஏற்கனவே 1MM ஐ செயல்படுத்தியிருந்தால் $24 உருவாக்குவது ஆகும்.",title:"{{brandTurbo}}",button:"{{brandTurbo}} செயல்படுத்தவும்"},videoSection:{omm:"பின்வரும் வீடியோவைப் பார்த்து, {{brandMiners}} எவ்வாறு செயல்படுகிறது என்பதை அறியவும்",turbominers:"பின்வரும் வீடியோவைப் பார்த்து, {{brandTurbo}} எவ்வாறு செயல்படுகிறது என்பதை அறியவும்"},turbo:{subtitle:"குறைந்த முயற்சியுடன் சுரங்கம் 1 இல் உங்கள் தொடக்கத்தை அதிகரிக்கவும்.",initial:"ஆரம்பம்",yield:"முடிவு",cta:"{{brandTurbo}} இயக்கவும்"},seeTBDocumentation:"{{brandTurbo}} ஆவணத்தைப் பார்க்கவும்",seeOMMDocumentation:"{{brandMiners}} ஆவணத்தைப் பார்க்கவும்"},p$={networkSummary:"நெட்வொர்க் சுருக்கம்",active:"செயலில்",activeNodes:"செயலில் முனைகள்",activeStations:"செயலில் உள்ள சுரங்கங்கள்",complete:"முடிக்கப்பட்டது",completeStations:"முடிக்கப்பட்ட சுரங்கங்கள்",errorLoading:"சுரங்கங்களை ஏற்றுவதில் பிழை",noMinesForCoin:"தேர்ந்தெடுக்கப்பட்ட நாணயத்திற்கு சுரங்கங்கள் எதுவும் இல்லை",startDate:"தொடக்க தேதி",statuses:{active:"சொத்து",finalized:"இறுதி செய்யப்பட்டது",in_progress:"செயல்பாட்டில் உள்ளது",inactive:"சும்மா",pending:"காதணி"},techSpecs:"தொழில்நுட்ப விவரக்குறிப்புகள்",title:"என் ஒப்பந்தங்கள்",you:"நீங்கள்",noTurboMine:"உங்களிடம் இன்னும் {{brandTurbo}} இல்லை.",buyTurboMine:"{{brandTurbo}} வாங்கவும்",minePlural:"சுரங்கங்கள்",mineSingular:"என்னுடையது",minesFor:"ஒப்பந்தங்கள் {{currency}}",turboContracts:"{{brandTurbo}} ஒப்பந்தம்",viewDetails:"விவரங்களைப் பார்க்கவும்",notFound:"என்னுடையது கிடைக்கவில்லை.",accumulated:"திரட்டப்பட்டது",currency:"நாணயம்",invalidId:"தவறான என்னுடைய ஐடி.",level:"நிலை",level1Direct:"நிலை 1 (நேரடி)",level2Secondary:"நிலை 2 (இரண்டாம் நிலை)",mineLevel:"என்னுடைய நிலை",networkFillInsightPrefix:"உங்கள் நெட்வொர்க் உள்ளது",networkFillInsightSuffix:"முனைகள் நிரப்பப்பட்டன",pairedNodes:"ஜோடி முனைகள்",pendingEarnings:"நிலுவையில் உள்ளது",sponsorId:"ஸ்பான்சர் பயனர் ஐடி",totalNetworkEarnings:"மொத்த நெட்வொர்க் வருவாய்",viewSponsorProfile:"ஸ்பான்சர் சுயவிவரத்தைக் காண்க",OMDBLevelsUnlocked:"OMDB நிலைகள்",OMDLevelsUnlocked:"OMD நிலைகள்",USDTLevelsUnlocked:"USDT நிலைகள்",totalLevelsUnlocked:"திறக்கப்பட்ட நிலைகள்"},g$={addBSC:"BSC நெட்வொர்க்கைச் சேர்க்கவும்",addBSCNetworkText:"மெட்டாமாஸ்க்கிற்கான பைனான்ஸ் ஸ்மார்ட் நெட்வொர்க்கை நீங்கள் இன்னும் சேர்க்கவில்லை.",addOMD:"OMD ஐ சேர்க்கவும்",addOMDWalletText:"நீங்கள் இன்னும் உங்கள் {{brandDollars}} வாலட்டை மெட்டாமாஸ்கில் சேர்க்கவில்லை.",bscNetworkConnected:"இணைக்கப்பட்ட BSC நெட்வொர்க்",description:"உங்கள் ஸ்பான்சரை அமைக்கவும், ஸ்மார்ட் ஒப்பந்தங்களை அங்கீகரிக்கவும், உங்கள் சுரங்க முனையை கையகப்படுத்தவும் கீழே உள்ள படிகளைப் பின்பற்றவும்.",omdWalletConnected:"இணைக்கப்பட்ட OMD வாலட்",title:"சுரங்கங்களைப் பெறுங்கள்",transactionDetails:"பரிவர்த்தனை விவரங்கள்",alreadyHasTurbo:"உங்களிடம் ஏற்கனவே {{brandTurbo}} உள்ளது",alreadyHasMaxLevel:"உங்களிடம் ஏற்கனவே அதிகபட்ச சுரங்கம் உள்ளது",buy:"என்னுடையதை வாங்கு",buyTurbo:"{{brandTurbo}} வாங்கவும்",calloutErc20:"உங்கள் சங்கிலியில் {{token}} (BEP-20) இல் பணம் செலுத்தப்படுகிறது; உங்கள் பணப்பை தானாகவே நெட்வொர்க்கை மாற்றும். அந்த நெட்வொர்க்கில் உங்களிடம் {{token}} மற்றும் எரிவாயு இருப்பு இருப்பதை உறுதிசெய்யவும்.",calloutOmdb:"உங்கள் பணப்பையிலிருந்து (நெட்வொர்க் கேஸ் உட்பட) சொந்த OMDB இல் பணம் செலுத்தப்படுகிறது. உங்களிடம் போதுமான OMDB இருப்பு இருப்பதை உறுதிசெய்யவும்.",calloutTurbo:"{{brandTurbo}} உங்கள் வழக்கமான சுரங்கங்களில் இருந்து சுயாதீனமாக உள்ளது: அது அதன் சொந்த 2x2 மேட்ரிக்ஸை உருவாக்குகிறது மற்றும் உங்கள் நெட்வொர்க்கில் நுழையும் ஒவ்வொரு பேரனுக்கும் $6 USDT செலுத்துகிறது. நீங்கள் ஒன்றை மட்டுமே வைத்திருக்க முடியும்.",completeOnboarding:"ஆன்போர்டிங்கை முடிக்கவும்",levelOption:"நிலை {{level}} (${{price}})",loading:"சார்ஜ் ஆகிறது...",loadingPrice:"விலை ஏற்றப்படுகிறது...",mineCurrency:"என்னுடைய நாணயம்",mineLevel:"என்னுடைய நிலை",mineOmd:"OMD என்னுடையது",mineOmdb:"OMDB என்னுடையது",mineTab:"என்னுடையது",mineUsdt:"USDT என்னுடையது",onboardingComplete:"ஆன்போர்டிங்கை முடிக்கவும்",onboardingLabel:"ஆன்போர்டிங் (செயல்படுத்துதல் 3 சுரங்கங்கள்)",paymentCurrency:"பணம் செலுத்தும் நாணயம்",pendingTxWarning:"உங்கள் கட்டணம் ஏற்கனவே செலுத்தப்பட்டது (tx {{hash}}...). பதிவு தோல்வியடைந்தால், பணம் செலுத்தாமல் மீண்டும் முயற்சிக்கவும்.",priceLoading:"விலை இன்னும் ஏற்றப்படுகிறது. சிறிது நேரத்தில் மீண்டும் முயற்சிக்கவும்.",processing:"செயலாக்குகிறது...",retryButton:"மீண்டும் முயற்சிக்கவும் (ஏற்கனவே பணம் செலுத்தியுள்ளீர்கள்)",retryError:"மீண்டும் முயற்சிப்பதில் பிழை",successMine:"ஒப்பந்தம் வெற்றிகரமாக கையகப்படுத்தப்பட்டது! திசைதிருப்புகிறது...",successOnboarding:"ஆன்போர்டிங் முடிந்தது! திசைதிருப்புகிறது...",successTurbo:"{{brandTurbo}} வெற்றிகரமாக கையகப்படுத்தப்பட்டது! திசைதிருப்புகிறது...",turboMineCost:"{{brandTurbo}} செலவு",turboMineTab:"{{brandTurbo}}",valueToPay:"செலுத்த வேண்டிய தொகை",walletMismatch:"இணைக்கப்பட்ட பணப்பை ({{addr}}) உங்கள் கணக்கில் பதிவு செய்யப்பட்ட பணப்பையுடன் பொருந்தவில்லை. Connect the registered wallet.",youPay:"நீங்கள் செலுத்துங்கள் ({{token}})",currentPrice:"தற்போதைய விலை ({{currency}})",systemRoot:"அமைப்பு (ரூட்)",turboMineLabel:"{{brandTurbo}} (2x2 அணி, ஒரு சுரங்கத்திற்கு ${{cost}})",approxUsdt:"≈ {{amount}} USDT",balance:"இருப்பு"},b$={copy:"நகலெடுக்கவும்",createAccount:"கணக்கை உருவாக்கவும்",date:"தேதி",dontHaveAccount:"கணக்கு இல்லையா?",haveAccount:"உங்களிடம் ஏற்கனவே கணக்கு உள்ளதா?",level:"நிலை",loginHere:"உள்நுழையவும்",mine:"சுரங்கம்",next:"தொடர்ந்து",page:"பக்கம்",prev:"முன்னாள்",register:"இங்கே பதிவு செய்யுங்கள்",retry:"மீண்டும் முயற்சிக்கவும்",search:"தேடுங்கள்",sponsor:"ஸ்பான்சர் ஐடி",status:"மாநிலம்",user:"பயனர்",wallet:"கிரிப்டோ வாலட்",all:"அனைத்து",processing:"செயலாக்குகிறது...",copied:"✓ நகலெடுக்கப்பட்டது",total:"மொத்தம்",unknownError:"அறியப்படாத பிழை",connectWallet:"Wallet ஐ இணைக்கவும்",buy:"வாங்க"},y$={applied:"பயன்படுத்தப்பட்டது!",apply:"விண்ணப்பிக்கவும்",cancel:"ரத்து செய்",defaultTitle:"கூப்பன்",empty:"உங்களிடம் இன்னும் கூப்பன்கள் எதுவும் இல்லை.",enterPromoCode:"விளம்பரக் குறியீட்டை உள்ளிடவும்",error:{fetchFailed:"கூப்பன்களை ஏற்ற முடியவில்லை. மீண்டும் முயற்சிக்கவும்."},expires:"காலாவதியாகும்:",loading:"உங்கள் கூப்பன்களை ஏற்றுகிறது...",noExpiry:"தேதியிடப்படாதது",promoCodePlaceholder:"எ.கா. OMD-2024-BOOST",redeemed:"மீட்டெடுக்கப்பட்டது",status:"மாநிலம்:",title:"எனது OMD கூப்பன்கள்",used:"பயன்படுத்தப்பட்டது",usedCoupons:"பயன்படுத்திய கூப்பன்கள்",copied:"நகலெடுக்கப்பட்டது!",copyCode:"நகல் குறியீடு"},v$={mineNumber:"சுரங்கம் {{level}}",minesCount:"{{count}} சுரங்கங்கள்",available:"கிடைக்கும்",buyContract:"ஒப்பந்தத்தை வாங்கவும்",completedMines:"முடிக்கப்பட்ட சுரங்கங்கள்",connectPortal:"போர்ட்டலுடன் இணைக்கவும்",description:"ஒரு புதுமையான ஸ்மார்ட் ஒப்பந்த அமைப்பு. ஸ்மார்ட் மைனிங். உண்மையான முடிவுகள்.",diamondEra:"வைர சகாப்தம்",emeraldEra:"மரகத சகாப்தம்",erasDescription:"உங்கள் சுரங்க நெட்வொர்க்கின் முன்னேற்றத்தைக் காணவும் மற்றும் ஒவ்வொரு டிஜிட்டல் விரிவாக்க சுழற்சியிலும் மறைக்கப்பட்ட பொக்கிஷங்களை திறக்கவும்.",erasTitle:"சகாப்தங்கள் மற்றும் வெகுமதிகளின் பரிணாமம்",goldEra:"அது தங்கமாக இருந்தது",inviteYourTeam:"இந்த இணைப்பின் மூலம் உங்கள் குழுவை அழைத்து, உங்களின் அடுத்த வெகுமதிக்கான புள்ளிகளைக் குவிக்கவும்",newlyJoined:"புதிதாக இணைக்கப்பட்டது",platinumEra:"பிளாட்டினம் சகாப்தம்",rewardTreasures:"வெகுமதி பொக்கிஷங்கள்",seeDetails:"விவரங்களைப் பார்க்கவும்",totalParticipants:"மொத்த பங்கேற்பாளர்கள்",totalUsers:"மொத்த பயனர்கள்",userId:"பயனர் ஐடி",usersLast24h:"பயனர்கள் (24 மணிநேரம்)",viewMyCoupons:"எனது கூப்பன்களைப் பார்க்கவும்",alreadyVerified:"போர்ட்டலில் ஏற்கனவே அங்கீகரிக்கப்பட்டது",epochLoading:"சகாப்த முன்னேற்றத்தை ஏற்றுகிறது...",epochRequirements:"சகாப்தத்தை அடைவதற்கான தேவைகள் {{nextEpoch}}",maxEpochMessage:"நீங்கள் இப்போது கணினியில் கிடைக்கக்கூடிய மிக உயர்ந்த சகாப்த நிலையில் இருக்கிறீர்கள்.",maxEpochTitle:"நீங்கள் அதிகபட்ச சகாப்தத்தை அடைந்துவிட்டீர்கள்!",reqCompleted:"நிரப்பப்பட்டது",reqPending:"காதணி",consecutiveLevels:"தொடர்ச்சியான நிலைகள்",epochRequirementsHint:`ஒவ்வொரு நாணயத்திலும் முடிக்கப்பட்ட சுரங்கத்துடன் (முழு அணி) தொடர்ச்சியான நிலைகளை (நிலை 1 இலிருந்து) கணக்கிடுகிறது. 
ஒரு முழுமையற்ற நிலை ஸ்ட்ரீக்கை உடைக்கிறது.`,wallet:"பணப்பை",minesProgression:"என்னுடைய முன்னேற்றம்",minesDesc:"உங்கள் வெகுமதிகளை அதிகரிக்க புதிய சுரங்கங்களைப் பெறுங்கள்",tapToView:"முடிக்கப்பட்ட சுரங்கத்தின் விவரங்களைப் பார்க்க அதைத் தட்டவும்",currentLevel:"தற்போதைய சுரங்கம்",currentBalance:"தற்போதைய வாலட் இருப்பு"},x$={destination:"இலக்கு",locked:"தடுக்கப்பட்டது",obtainCoupon:"கூப்பனைப் பெறுங்கள்",couponObtained:"கூப்பன் கிடைத்தது"},w$={clearFilters:"சுத்தமான",empty:"ஆர்டர்கள் எதுவும் இல்லை",errorTitle:"ஆர்டர்களை ஏற்றுவதில் பிழை",filterAll:"அனைத்து",filterStatus:"மாநிலம்",filterType:"பையன்",pendingOrders:"நிலுவையில் உள்ள ஆர்டர்கள்",retry:"மீண்டும் முயற்சிக்கவும்",status:{cancelled:"ரத்து செய்யப்பட்டது",completed:"நிரப்பப்பட்டது",processing:"செயலாக்கம்",rejected:"மறுத்தார்",locking:"தடுக்கப்பட்டது"},subtitle:"உங்கள் பரிவர்த்தனைகள் மற்றும் ஒப்பந்த கையகப்படுத்துதல்களின் முழுமையான பதிவை மதிப்பாய்வு செய்து நிர்வகிக்கவும்.",title:"ஆர்டர் வரலாறு",totalEarned:"மொத்தம் வெற்றி பெற்றது",types:{activationFee:"செயல்படுத்தும் கட்டணம்",earning:"வெற்றியாளர்",fee:"கமிஷன்",investment:"முதலீடு",purchase:"சுரங்க ஒப்பந்தம்",repurchase:"ஒப்பந்தம் திரும்பப் பெறுதல்",swap:"பரிமாற்றம்",swapOnboarding:"ஆரம்ப பரிமாற்றம்",withdrawal:"நிதி திரும்பப் பெறுதல்"},waitingConfirmation:"உறுதிப்படுத்தலுக்காக காத்திருக்கிறது",filterAllCurrencies:"அனைத்து நாணயங்கள்",filterAllStatus:"அனைத்து நிலைகளும்",filterAllTypes:"அனைத்து வகைகளும்",filterCurrency:"நாணயம்"},k$={referAFriend:"ஒரு நண்பரை அழைக்கவும்",referAFriendDesc:"உங்கள் சக ஊழியர்களை சுற்றுச்சூழல் அமைப்புக்கு அழைத்து, சகாப்தங்களை செயல்படுத்தவும் வெகுமதிகளை உருவாக்கவும் ஒன்றாக நெட்வொர்க்கை வளர்க்கவும்",direct:"நேரடி",levelN:"நிலை {{level}}",directReferral:"நேரடி",sponsor:"ஸ்பான்சர்",walletColumn:"பணப்பை",referredColumn:"இணை",father:"ஸ்பான்சர் துணை",network:"இணைப்பு நெட்வொர்க்",loadingReferrals:"இணைப்புகளை ஏற்றுகிறது...",noReferrals:"இணைப்புகள் இல்லாமல்",loadingSponsor:"ஸ்பான்சரை ஏற்றுகிறது...",noSponsor:"ஸ்பான்சர் இல்லாமல்",showingCount:"{{total}} இல் {{shown}} இணைப்புகள் காட்டப்படுகின்றன",pageInfo:"பக்கம் <bold>{{page}}</bold> / {{total}}"},S$={configure:"அமைக்கவும்",profile:"சுயவிவரம்",saveChanges:"மாற்றங்களைச் சேமிக்கவும்",security:"பாதுகாப்பு",securityPin:"பாதுகாப்பு பின்",securityPinDesc:"உள்ளமைவு மாற்றங்களுக்குத் தேவை",subtitle:"உங்கள் சுரங்க முனையின் அடையாளம், உங்கள் சொத்துக்களின் பாதுகாப்பு மற்றும் உங்கள் தகவல் தொடர்பு விருப்பங்களை நிர்வகிக்கவும்.",title:"கணக்கு அமைப்புகள்",twoFa:"2FA அங்கீகாரம்",twoFaDesc:"Google Authenticator மூலம் உங்கள் திரும்பப் பெறுதல்களைப் பாதுகாக்கவும்",walletAddress:"திரும்பப் பெறுதல் வாலட் (BTC/USDT)"},T$={contracts:"சுரங்கங்களைப் பெறுங்கள்",darkMode:"இருண்ட தீம்",dashboard:"தொடங்கு",history:"ஆர்டர் வரலாறு",lightMode:"தெளிவான தீம்",logOut:"வெளியேறு",myStations:"என் ஒப்பந்தங்கள்",referrals:"துணை நிறுவனங்கள்",support:"ஆதரவு",users:"பயனர்கள்",help:"உதவி"},A$={approxEarnings:"தோராயமான வருவாய்",searchPlaceholder:"ஐடி மூலம் தேடு...",title:"பதிவு செய்யப்பட்ட சுரங்கத் தொழிலாளர்கள்",active:"சொத்து",noStations:"இந்தப் பயனரிடம் பதிவு செய்யப்பட்ட சுரங்கங்கள் எதுவும் இல்லை.",notFound:"பயனர் கிடைக்கவில்லை."},C$={generalLoginError:"உள்நுழையும்போது பிழை ஏற்பட்டது, பிறகு முயற்சிக்கவும்.",generalRegError:"பதிவு செய்யும் போது பிழை ஏற்பட்டது, பிறகு முயற்சிக்கவும்",tooManyRequests:"முயற்சிகள் அதிகமாக உள்ளன. சிறிது நேரம் காத்திருந்து மீண்டும் முயற்சிக்கவும்.",walletInvalid:"பணப்பையானது செல்லுபடியாகும் Ethereum Wallet ஆக இருக்க வேண்டும்",walletRequired:"பணப்பையின் முகவரி தேவை",referrerInvalid:"சரியான பரிந்துரை எண் அல்லது செல்லுபடியாகும் பணப்பை முகவரியாக இருக்க வேண்டும்"},E$={referrer:"இணைப்பு ஐடி அல்லது பணப்பை எண் (விரும்பினால்)",referrerPlaceholder:"ஐடி அல்லது 0x...",activation:"செயல்படுத்துதல்",mineOmd:"சுரங்கம் · OMD",mineOmdb:"சுரங்கம் · OMDB",mineUsdt:"சுரங்கம் · USDT",omCostHint:"ஆன்போர்டிங் OM மைனர்கள்: ஒரு மரத்திற்கு ஒரு சுரங்கத்தை செயல்படுத்துதல் (USDT, OMD மற்றும் OMDB).",debitCurrency:"பற்று வைக்கப்படும்",turboCostHint:"{{brandTurbo}}: ஒரு சுரங்கத்திற்கு $6 USDT, USDT இல் 100% தீர்வு.",pri